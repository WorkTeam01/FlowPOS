# ─── Identidad del negocio ────────────────────────────────────────────────────
# Nombre que aparece en el header, login, PDFs y títulos de página
APP_NAME=FlowPOS

# Versión visible y de referencia de la aplicación
APP_VERSION=1.0.0

# Símbolo de moneda local (ej: Bs, $, €, S/, COP)
APP_CURRENCY=Bs

# URL base del proyecto — debe terminar con /
# Ejemplos:
#   http://localhost/mi-sistema/
#   https://ventas.miempresa.com/
APP_URL=http://localhost/FlowPOS/

# Zona horaria (ver: https://www.php.net/manual/en/timezones.php)
# Ejemplos: America/La_Paz, America/Bogota, America/Lima, Europe/Madrid
TIMEZONE=America/La_Paz

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=flowpos
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ─── Desarrollo ───────────────────────────────────────────────────────────────
# true  → muestra errores PHP en pantalla
# false → silencia errores (usar en producción)
DEBUG=false
